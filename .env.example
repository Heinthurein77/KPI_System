ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string

# Leave unset for local SQLite. Set to a Neon.tech Postgres URL in production:
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Comma-separated list of origins allowed to call this API (the deployed React
# app's URL(s)). Defaults to the local Vite dev server if unset.
CORS_ORIGINS=http://localhost:5173
